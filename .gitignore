# Python environment (shared by TTS-Handler and TTS-Tester)
.venv/
__pycache__/
*.pyc

# Vendored upstream repo (clone fresh, see TTS-Handler/README.md, not ours to version)
TTS-Handler/GPT-SoVITS/

# Model weights / checkpoints, never commit these
*.ckpt
*.pth

# Voice reference audio: block by default (never upload someone's private
# recording), except the copyright-free Kokoro-synthesized defaults this
# repo actually ships. Keep the folder structure for any blocked voice (so
# it's obvious where a voice goes), drop the audio itself.
TTS-Handler/voices/**/*.wav
TTS-Handler/voices/**/*.mp3
TTS-Handler/voices/**/*.m4a
TTS-Handler/voices/**/*.flac
!TTS-Handler/voices/**/.gitkeep
!TTS-Handler/voices/kokoro_female/reference.wav
!TTS-Handler/voices/kokoro_male/reference.wav
!TTS-Handler/voices/kokoro_alt/reference.wav

# Auto-transcribed transcripts (see voices.py) are private to whatever voice
# they're next to, same rule as the audio: block by default, allow the
# shipped defaults only.
TTS-Handler/voices/**/prompt.txt
!TTS-Handler/voices/kokoro_female/prompt.txt
!TTS-Handler/voices/kokoro_male/prompt.txt
!TTS-Handler/voices/kokoro_alt/prompt.txt

# Generated audio output (dev/testing only)
TTS-Handler/test_audio/
test_audio/

# Secrets, never commit API keys
.env
TTS-Tester/settings.local.json

# OS junk
.DS_Store
Thumbs.db
